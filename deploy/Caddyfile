# Caddy 리버스 프록시 — TLS 종단(사내 폐쇄망, 명시적 self-signed 인증서).
#
# 목적: meetscript(FastAPI :8088)를 HTTPS 로 감싸 ① 로그인 비번/JWT/Anthropic 키 평문
#       전송을 막고 ② 브라우저 보안 컨텍스트를 만족시켜 마이크 녹음(getUserMedia)이 LAN
#       IP 접속에서도 동작하게 한다.
#
# [왜 tls internal 이 아니라 명시적 인증서인가]
#   사용자가 raw IP(https://<IP>:포트)로 접속하면 TLS ClientHello 에 SNI 가 없다(SNI 는 호스트명
#   전용). Caddy 의 `tls internal` 은 SNI 로 인증서를 고르므로, SNI 없는 IP 접속에서는 인증서를
#   선택하지 못해 'tlsv1 alert internal error' 로 핸드셰이크가 실패한다(개발 컨테이너에서 재현·
#   확인). 그래서 IP 를 SAN 에 박은 self-signed 인증서를 만들어(deploy/gen-cert.sh) Caddy 에
#   직접 물린다. `:443`(호스트 매칭 없음) + 명시적 cert 라 SNI 유무·호스트 포트매핑과 무관하게
#   동작한다(검증 완료).
#
# 인증서 생성: deploy/gen-cert.sh 가 .env.deploy 의 SITE_HOST(접속 IP/호스트명)를 SAN 에 넣어
#   deploy/certs/{cert,key}.pem 를 만든다. compose 가 이 디렉토리를 /etc/caddy/certs 로 ro 마운트.
#   브라우저는 자체서명이라 첫 1회 경고를 띄운다(README 'TLS' 절: 루트 CA 신뢰 등록 시 사라짐).
{
	# 공인 ACME 비활성(폐쇄망). 자동 HTTP→HTTPS 리다이렉트도 끔(80 미공개).
	auto_https off
}

:443 {
	tls /etc/caddy/certs/cert.pem /etc/caddy/certs/key.pem
	# 업로드(회의 오디오 base64)가 크므로 본문 상한을 넉넉히(기본 제한 회피). 과대 페이로드 차단.
	request_body {
		max_size 200MB
	}
	reverse_proxy meetscript:8088
}
