# 배포용 환경변수 예시. 복사해서 deploy/.env.deploy 로 저장하고 비밀값을 채운다.
#   cp deploy/.env.deploy.example deploy/.env.deploy
# .env.deploy 는 비밀값이 들어가므로 절대 커밋하지 않는다(.gitignore 확인).

# ----- 인증/계정 -----
# 초기 계정 시드. 형식: id:pw,id:pw  (사용자가 비번을 바꾸면 재기동해도 보존됨)
WEB_AUTH_USERS=admin:CHANGE_ME_STRONG,dev:CHANGE_ME_STRONG
# 관리자 권한 부여할 id 목록(쉼표 구분)
WEB_AUTH_ADMINS=admin
# prune OFF 필수: 계정 진실원천은 DB. 스크립트(tools/bulk_create_users.py)나 셀프로 만든
# 계정을 부팅 시 지우지 않는다. (1로 두면 WEB_AUTH_USERS 에 없는 계정이 재기동마다 삭제됨)
WEB_AUTH_PRUNE=0
# JWT 서명 키. 반드시 길고 무작위한 값으로 교체(예: openssl rand -hex 32).
JWT_SECRET=CHANGE_ME_RANDOM_HEX

# ----- 후처리 백엔드 -----
# 정제는 segment 당 1콜이라 비싸므로 passthrough(원문 유지) 권장.
WEB_CLEAN_BACKEND=passthrough
# 요약/추출은 회의당 1콜이라 저비용 -> claude(agent_cli). 단, 자격증명은 사용자별로
# 각자 설정 화면에서 입력해야 동작(전역 키 주입 없음). 미설정 사용자는 요약/추출 빈 값.
WEB_EXTRACT_BACKEND=agent_cli
WEB_SUMMARIZE_BACKEND=agent_cli
# agent_cli(claude -p) 콜당 타임아웃(초). 긴 회의 단일콜 대비 여유있게.
AGENT_CLI_TIMEOUT=600
# 동시 STT 추론 수. 초과 요청은 대기(잡 status=queued, 프론트 "처리 대기 중…").
# GPU 1장 + 요청마다 모델 load 구조라 기본 1(직렬) 권장. VRAM 여유 시 2로 상향 가능.
WEB_STT_CONCURRENCY=1

# ----- 경로(보통 기본값 사용, 이미지 ENV 와 동일) -----
# COHERE_MODEL_PATH=/app/models/cohere-transcribe-03-2026
# WEB_FRONTEND_DIST=/app/web-dist
# 전처리 인핸서(기본 wpe). gtcrn 까지 쓰려면 "wpe,gtcrn", 끄려면 빈 값.
# ENHANCERS=wpe

# ----- 호스트측(compose 변수) -----
# git clone 한 백엔드/프론트 repo 경로(빌드 컨텍스트)
BACKEND_DIR=/opt/meetscript/app
FRONTEND_DIR=/opt/meetscript/frontend
# 모델 가중치(3.9G)를 1회 배치한 호스트 경로 (필수 - docker cp 또는 재다운로드)
MODELS_DIR=/opt/meetscript/models
# DB(SQLite)·산출물 영속 호스트 경로 (host-dir bind). DB 는 여기 web/meetings.db 로 떨어진다.
# 기존 계정 DB 를 승계하려면 이 경로의 web/ 에 meetings.db 를 미리 복사해 둔다.
DATA_DIR=/opt/meetscript/data
# 호스트에서 노출할 포트(HTTP). 사용자는 http://<LAN-IP>:49152 로 접속.
HOST_PORT=49152
