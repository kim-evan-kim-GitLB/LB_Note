{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Cohere Smoke (30s clip)",
      "type": "debugpy",
      "request": "launch",
      "module": "src._smoke",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Cohere Evaluate (모든 samples wav)",
      "type": "debugpy",
      "request": "launch",
      "module": "src.evaluate",
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false
    },
    {
      "name": "Cohere Run (단일 wav)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/run.py",
      "args": ["/home/evan/Claude_workspace/lb-note-archive/samples/ko_office_noise_off.wav"],
      "console": "integratedTerminal",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
